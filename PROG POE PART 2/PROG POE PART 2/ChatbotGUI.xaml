<Window x:Class="PROG_POE_PART_2.ChatbotGUI"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Chatbot" Height="400" Width="600">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBox x:Name="ChatOutput" Grid.Row="0"
                 TextWrapping="Wrap" IsReadOnly="True"
                 VerticalScrollBarVisibility="Auto"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal">
            <TextBox x:Name="UserInput" Width="400" Margin="5"/>
            <Button Content="Send" Width="100" Click="SendMessage"/>
        </StackPanel>
    </Grid>
</Window>